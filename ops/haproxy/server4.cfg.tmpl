# Generated by scripts/render-server4-gateway.mjs. Do not edit the rendered file.
# Candidate release: {{CANDIDATE_RELEASE_SHA}}
# Traffic: stable={{STABLE_WEIGHT_PERCENT}}% candidate={{CANDIDATE_WEIGHT_PERCENT}}%

global
    log stdout format raw local0
    maxconn 4096
    hard-stop-after 70m
    stats socket /run/haproxy-admin.sock mode 660 level admin expose-fd listeners
    stats timeout 30s

defaults
    log global
    mode http
    option httplog
    option dontlognull
    option http-keep-alive
    timeout connect 5s
    timeout client 65m
    timeout server 65m
    timeout tunnel 65m
    timeout http-request 10s
    timeout http-keep-alive 1m
    timeout queue 30s

resolvers docker
    nameserver docker 127.0.0.11:53
    resolve_retries 3
    timeout resolve 1s
    timeout retry 1s
    hold valid 10s
    hold other 30s
    hold refused 30s
    hold nx 30s
    hold timeout 30s
    hold obsolete 30s

# Loopback-only runtime identity and backend statistics. These listeners are
# intentionally not published by Compose; the deployment controller captures
# them from inside the container after every master-worker reload.
frontend gateway_runtime_identity
    bind 127.0.0.1:8404
    http-request return status 200 content-type text/plain string "{{ACTIVE_CONFIG_ID}}" if { path -i /config }
    http-request return status 404 content-type text/plain string not-found

listen gateway_runtime_stats
    bind 127.0.0.1:8405
    mode http
    stats enable
    stats uri /stats
    stats show-node server4-gateway
    stats show-desc {{ACTIVE_CONFIG_ID}}

frontend zutomayo_gateway
    bind :8080

    acl is_liveness path -i /health
    acl is_readiness path -i /ready
    http-request return status 200 content-type text/plain string healthy if is_liveness
{{GATEWAY_READINESS_RULES}}

    # The cookie stores one durable bucket in [0, 99]. Raising the threshold
    # from 10 to 50 to 100 preserves every client already in the candidate cohort.
    acl cohort_cookie_valid req.cook({{COHORT_COOKIE_NAME}}) -m reg ^([0-9]|[1-9][0-9])$
    http-request set-var(txn.cohort_bucket) req.cook({{COHORT_COOKIE_NAME}}) if cohort_cookie_valid
    http-request set-var(txn.cohort_bucket) rand(100) unless cohort_cookie_valid
    http-request set-var(txn.set_cohort_cookie) str(yes) unless cohort_cookie_valid
    acl candidate_cohort var(txn.cohort_bucket) -m int lt {{CANDIDATE_WEIGHT_PERCENT}}
    http-response add-header Set-Cookie "{{COHORT_COOKIE_NAME}}=%[var(txn.cohort_bucket)]; Path=/; Max-Age=31536000; HttpOnly; Secure; SameSite=Lax" if { var(txn.set_cohort_cookie) -m str yes }
    acl slot_pin_blue req.cook({{SLOT_PIN_COOKIE_NAME}}) -m str blue
    acl slot_pin_green req.cook({{SLOT_PIN_COOKIE_NAME}}) -m str green
    acl slot_pin_valid req.cook({{SLOT_PIN_COOKIE_NAME}}) -m reg ^(blue|green)$
    acl release_slot_selected var(txn.release_slot) -m found
    http-response add-header Set-Cookie "{{SLOT_PIN_COOKIE_NAME}}=%[var(txn.release_slot)]; Path=/; Max-Age=7200; HttpOnly; Secure; SameSite=Lax" if { var(txn.set_slot_pin) -m str yes }

    # Reservation responses advertise a process-specific public path. Capture
    # that route before stripping it so it always wins over cohort routing.
{{DIRECT_PLATFORM_REQUEST_RULES}}

    acl is_matchmake path_reg -i ^/matchmake(/|$)
{{COHORT_SELECTION_RULES}}

{{DIRECT_PLATFORM_BACKEND_RULES}}
{{COHORT_BACKEND_RULES}}

{{BACKENDS}}
