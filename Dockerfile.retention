FROM node:22-alpine

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci --ignore-scripts --omit=dev
COPY api/retentionService.cjs ./api/retentionService.cjs
COPY api/runtimeSecurityConfig.cjs ./api/runtimeSecurityConfig.cjs
COPY scripts/run-retention.cjs ./scripts/run-retention.cjs

USER node
CMD ["node", "scripts/run-retention.cjs"]
