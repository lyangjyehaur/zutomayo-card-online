{
  "name": "zutomayo-card-online",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && vite build",
    "typecheck": "tsc --noEmit",
    "smoke": "node --import tsx scripts/game-smoke.ts",
    "smoke:online": "node --import tsx scripts/online-smoke.ts",
    "preview": "vite preview",
    "server": "node --import tsx src/server.ts"
  },
  "dependencies": {
    "@types/koa-static": "^4.0.4",
    "boardgame.io": "^0.50.2",
    "koa-static": "^5.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tsx": "^4.22.4"
  },
  "devDependencies": {
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.5.2",
    "typescript": "~5.8.3",
    "vite": "^7.0.0"
  }
}
