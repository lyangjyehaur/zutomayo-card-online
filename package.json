{
  "name": "zutomayo-card-online",
  "private": true,
  "version": "0.1.3",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && npm run typecheck:scripts && vite build",
    "typecheck": "tsc --noEmit",
    "typecheck:scripts": "tsc --noEmit -p tsconfig.scripts.json",
    "smoke": "node --import tsx scripts/game-smoke.ts",
    "smoke:api": "node --import tsx scripts/api-smoke.ts",
    "smoke:online": "node --import tsx scripts/online-smoke.ts",
    "smoke:online-consistency": "ONLINE_SMOKE_MODE=consistency node --import tsx scripts/online-smoke.ts",
    "smoke:responsive": "npm run smoke:ui-responsive && npm run smoke:admin-responsive && npm run smoke:battle-responsive && npm run smoke:online-lobby-responsive && npm run smoke:tools-responsive",
    "smoke:ui-responsive": "node scripts/ui-responsive-smoke.mjs",
    "smoke:admin-responsive": "node scripts/admin-responsive-smoke.mjs",
    "smoke:battle-responsive": "node scripts/battle-responsive-smoke.mjs",
    "smoke:online-lobby-responsive": "node scripts/online-lobby-responsive-smoke.mjs",
    "smoke:tools-responsive": "node scripts/tools-responsive-smoke.mjs",
    "rule:audit": "node --import tsx scripts/rule-audit.ts",
    "migrate:sqlite-to-pg": "node --import tsx scripts/migrate-sqlite-to-pg.ts",
    "seed:cards": "node --import tsx scripts/seed-cards-pg.ts",
    "preview": "vite preview",
    "server": "node --import tsx src/server.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@sentry/node": "^10.63.0",
    "@sentry/react": "^10.63.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "@types/koa-static": "^4.0.4",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.10",
    "boardgame.io": "^0.50.2",
    "ioredis": "^5.4.2",
    "koa-helmet": "^9.0.0",
    "koa-static": "^5.0.0",
    "pg": "^8.13.1",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.18.0",
    "tsx": "^4.22.4",
    "web-vitals": "^5.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@sentry/vite-plugin": "^5.3.0",
    "@tailwindcss/vite": "^4.3.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.5.2",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "fast-check": "^4.8.0",
    "lucide-react": "^0.468.0",
    "prettier": "^3.8.5",
    "tailwindcss": "^4.3.1",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^7.0.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9"
  }
}
