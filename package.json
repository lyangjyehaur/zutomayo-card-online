{
  "name": "zutomayo-card-online",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "verify": "npm run format:check:tracked && npm run version:check && npm run lint && npm run typecheck && npm run typecheck:scripts && npm test && npm run build",
    "build": "npm run typecheck && npm run typecheck:scripts && vite build",
    "typecheck": "tsc --noEmit",
    "typecheck:scripts": "tsc --noEmit -p tsconfig.scripts.json",
    "smoke": "node --import tsx scripts/game-smoke.ts",
    "smoke:api": "node --import tsx scripts/api-smoke.ts",
    "smoke:online": "node --import tsx scripts/online-smoke.ts",
    "smoke:online-consistency": "ONLINE_SMOKE_MODE=consistency node --import tsx scripts/online-smoke.ts",
    "smoke:platform-deployment": "node --import tsx scripts/platform-deployment-smoke.ts",
    "smoke:responsive": "npm run smoke:ui-responsive && npm run smoke:admin-responsive && npm run smoke:battle-responsive && npm run smoke:online-lobby-responsive && npm run smoke:tools-responsive",
    "smoke:ui-responsive": "node scripts/ui-responsive-smoke.mjs",
    "smoke:admin-responsive": "node scripts/admin-responsive-smoke.mjs",
    "smoke:battle-responsive": "node scripts/battle-responsive-smoke.mjs",
    "smoke:online-lobby-responsive": "node scripts/online-lobby-responsive-smoke.mjs",
    "smoke:tools-responsive": "node scripts/tools-responsive-smoke.mjs",
    "rule:audit": "node --import tsx scripts/rule-audit.ts",
    "migrate:sqlite-to-pg": "node --import tsx scripts/migrate-sqlite-to-pg.ts",
    "seed:cards": "node --import tsx scripts/seed-cards-pg.ts",
    "audit:card-official-texts": "node --import tsx scripts/audit-card-official-texts.ts",
    "import:card-official-texts": "npm run audit:card-official-texts && node --import tsx scripts/import-card-official-texts-pg.ts",
    "preview": "vite preview",
    "server": "node --import tsx src/server.ts",
    "platform": "node --import tsx src/platform/server.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "format:check:tracked": "node scripts/prettier-tracked.mjs",
    "version:check": "node scripts/check-version-sync.mjs",
    "i18n:check": "tsx scripts/check-i18n.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "load:api": "k6 run load-tests/api-load.js",
    "load:ws": "k6 run load-tests/websocket-load.js",
    "load:auth": "k6 run load-tests/auth-load.js",
    "load:matchmaking": "k6 run load-tests/matchmaking-load.js",
    "db:migrate": "node scripts/db-migrate.cjs up",
    "db:migrate:down": "node scripts/db-migrate.cjs down",
    "db:migrate:make": "node scripts/db-migrate.cjs create",
    "prepare": "husky",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:report": "playwright show-report",
    "e2e:smoke": "playwright test smoke"
  },
  "dependencies": {
    "@colyseus/core": "^0.17.44",
    "@colyseus/redis-driver": "^0.17.7",
    "@colyseus/redis-presence": "^0.17.7",
    "@colyseus/schema": "^4.0.27",
    "@colyseus/ws-transport": "^0.17.13",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.220.0",
    "@opentelemetry/instrumentation-express": "^0.68.0",
    "@opentelemetry/instrumentation-http": "^0.220.0",
    "@opentelemetry/instrumentation-ioredis": "^0.68.0",
    "@opentelemetry/instrumentation-koa": "^0.68.0",
    "@opentelemetry/instrumentation-pg": "^0.72.0",
    "@opentelemetry/instrumentation-socket.io": "^0.67.0",
    "@opentelemetry/resources": "^2.9.0",
    "@opentelemetry/sdk-node": "^0.220.0",
    "@opentelemetry/semantic-conventions": "^1.43.0",
    "@sentry/node": "^10.63.0",
    "@sentry/react": "^10.63.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "@types/koa-static": "^4.0.4",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.10",
    "boardgame.io": "^0.50.2",
    "colyseus.js": "^0.16.22",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "ioredis": "^5.4.2",
    "koa-helmet": "^9.0.0",
    "koa-static": "^5.0.0",
    "pg": "^8.13.1",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.18.0",
    "tsx": "^4.22.4",
    "web-vitals": "^5.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.61.1",
    "@sentry/vite-plugin": "^5.3.0",
    "@tailwindcss/vite": "^4.3.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.5.2",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "fast-check": "^4.8.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "lucide-react": "^0.468.0",
    "node-pg-migrate": "^8.0.4",
    "prettier": "^3.8.5",
    "tailwindcss": "^4.3.1",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^7.0.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,cjs,mjs}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,css,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
