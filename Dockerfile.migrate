FROM node:22-alpine

WORKDIR /app

# Keep migration dependencies and source in a dedicated image so deployment
# never builds migrations from an unrelated checkout.
COPY package.json package-lock.json ./
RUN npm ci --ignore-scripts
COPY migrations ./migrations
COPY scripts/db-migrate.cjs ./scripts/db-migrate.cjs

USER node
CMD ["npm", "run", "db:migrate"]
