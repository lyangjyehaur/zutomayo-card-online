FROM node:22.22.2-alpine@sha256:8ea2348b068a9544dae7317b4f3aafcdc032df1647bb7d768a05a5cad1a7683f

WORKDIR /app

# Keep migration dependencies and source in a dedicated image so deployment
# never builds migrations from an unrelated checkout.
RUN apk upgrade --no-cache \
    && npm install --global --prefix /opt/npm npm@12.0.1 \
    && rm -rf /usr/local/lib/node_modules/npm /usr/local/bin/npm /usr/local/bin/npx \
    && ln -s /opt/npm/bin/npm /usr/local/bin/npm \
    && ln -s /opt/npm/bin/npx /usr/local/bin/npx \
    && npm cache clean --force
COPY package.json package-lock.json ./
RUN npm ci --ignore-scripts
COPY migrations ./migrations
COPY data/card-english-extraction.json ./data/card-english-extraction.json
COPY data/card-english-human-reviews.json ./data/card-english-human-reviews.json
COPY data/card-official-errata.json ./data/card-official-errata.json
COPY scripts/card-english-ocr-overrides.json ./scripts/card-english-ocr-overrides.json
COPY api/schemaGate.cjs ./api/schemaGate.cjs
COPY api/runtimeSecurityConfig.cjs ./api/runtimeSecurityConfig.cjs
COPY api/relationshipEvents.cjs ./api/relationshipEvents.cjs
COPY api/observability.cjs ./api/observability.cjs
COPY api/matchmakingService.cjs ./api/matchmakingService.cjs
COPY api/accountMutationLock.cjs ./api/accountMutationLock.cjs
COPY api/relationshipOutbox.cjs ./api/relationshipOutbox.cjs
COPY api/adminAuthService.cjs ./api/adminAuthService.cjs
COPY api/adminCredentialService.cjs ./api/adminCredentialService.cjs
COPY api/adminSecretCrypto.cjs ./api/adminSecretCrypto.cjs
COPY scripts/db-migrate.cjs ./scripts/db-migrate.cjs
COPY scripts/migration-checksums.cjs ./scripts/migration-checksums.cjs
COPY scripts/migration-order-compat.cjs ./scripts/migration-order-compat.cjs
COPY scripts/postgres-role-gate.cjs ./scripts/postgres-role-gate.cjs
COPY scripts/postgres-role-tls-smoke.cjs ./scripts/postgres-role-tls-smoke.cjs
COPY scripts/db-schema-gate.cjs ./scripts/db-schema-gate.cjs
COPY scripts/card-data-gate.cjs ./scripts/card-data-gate.cjs
COPY scripts/release-card-data.cjs ./scripts/release-card-data.cjs
COPY scripts/audit-card-official-texts.ts ./scripts/audit-card-official-texts.ts
COPY scripts/import-card-official-texts-pg.ts ./scripts/import-card-official-texts-pg.ts
COPY scripts/verify-compose-role-env.mjs ./scripts/verify-compose-role-env.mjs
COPY scripts/create-admin.cjs ./scripts/create-admin.cjs
COPY scripts/relationship-outbox-pg-smoke.cjs ./scripts/relationship-outbox-pg-smoke.cjs
COPY scripts/admin-credential-pg-smoke.cjs ./scripts/admin-credential-pg-smoke.cjs
COPY scripts/redrive-relationship-outbox.cjs ./scripts/redrive-relationship-outbox.cjs

USER node
CMD ["npm", "run", "db:migrate:release"]
