# ZUTOMAYO CARD Online - Environment Variables Template
# Copy this file to .env and fill in your values

# === Database (PostgreSQL) ===
PG_HOST=localhost
PG_PORT=5432
PG_USER=zutomayo
PG_PASSWORD=your_secure_password_here
PG_DATABASE=zutomayo
PG_POOL_MAX=20

# === Cache & Queue (Redis) ===
REDIS_URL=redis://localhost:6379
REDIS_DB=0

# === Security (REQUIRED) ===
# Generate with: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_here_minimum_32_characters

# Admin panel password (at least 8 characters recommended)
ADMIN_PASSWORD=your_admin_password_here

# === API Server ===
API_PORT=3001

# === Game Server ===
PORT=3000

# CORS allowed origins (comma-separated, optional)
# ALLOWED_ORIGINS=https://example.com,https://app.example.com

# === Application Version ===
APP_VERSION=0.1.0
APP_BUILD_ID=0.1.0
GAME_RULES_VERSION=0.1.0

# === Error Tracking (GlitchTip / Sentry compatible) ===
# Backend DSN (game server + api server). Leave empty to disable.
# SENTRY_DSN=
# Frontend DSN (exposed to browser via VITE_ prefix). Leave empty to disable.
# VITE_SENTRY_DSN=
# VITE_SENTRY_TRACES_SAMPLE_RATE=0.1

# === Observability (Structured Logging + Metrics) ===
# pino log level (trace/debug/info/warn/error/fatal). Default: info
# LOG_LEVEL=info
# Max Socket.IO connections per IP on the game server. Default: 10
# MAX_CONN_PER_IP=10
# Prometheus metrics exposed at /metrics on both game (3000) and api (3001).
# Scrape: http://<host>:3000/metrics  and  http://<host>:3001/metrics

# === Analytics (Optional) ===
# VITE_UMAMI_WEBSITE_ID=
# VITE_UMAMI_SCRIPT_URL=
# VITE_UMAMI_HOST_URL=
# VITE_UMAMI_TELEMETRY_SCRIPT_URL=
# VITE_UMAMI_SECONDARY_WEBSITE_ID=
# VITE_UMAMI_SECONDARY_HOST_URL=

# === Maintenance ===
# Stale match cleanup (in milliseconds)
STALE_MATCH_TTL_MS=1800000
CLEANUP_INTERVAL_MS=300000

# === Card Seeding (Optional) ===
# SEED_CARDS_URL=
# SEED_CARD_API_URL=

# === PostgreSQL Backup (Optional, see scripts/pg-backup.sh) ===
# PG_BACKUP_DIR=/var/backups/zutomayo
# PG_BACKUP_RETENTION_DAYS=7
