# ZUTOMAYO CARD Online - Environment Variables Template
# Copy this file to .env and fill in your values

# === Database (PostgreSQL) ===
PG_HOST=localhost
PG_PORT=5432
PG_USER=zutomayo
PG_PASSWORD=your_secure_password_here
PG_DATABASE=zutomayo
PG_POOL_MAX=20
# Optional: DATABASE_URL takes precedence over PG_* vars for node-pg-migrate
# and the pg Pool when set. Leave unset to use the PG_* variables above.
# DATABASE_URL=postgresql://zutomayo:your_secure_password_here@localhost:5432/zutomayo

# === Cache & Queue (Redis) ===
REDIS_URL=redis://localhost:6379
REDIS_DB=0

# === Security (REQUIRED) ===
# Generate with: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_here_minimum_32_characters
# Auth session cookie. Keep Lax when frontend and API are same-site.
# Use AUTH_COOKIE_SAMESITE=None only when frontend and API are cross-site HTTPS origins.
# AUTH_COOKIE_DOMAIN=.example.com
# AUTH_COOKIE_SAMESITE=Lax

# Token TTL (seconds). Access token is short-lived (1h default); refresh token
# stored in HttpOnly cookie rotates on each /api/auth/refresh call.
ACCESS_TOKEN_TTL_SECONDS=3600
REFRESH_TOKEN_TTL_SECONDS=604800

# Admin panel password (at least 8 characters recommended)
ADMIN_PASSWORD=your_admin_password_here

# Cloudflare Turnstile (optional auth challenge)
# Leave TURNSTILE_SECRET_KEY empty to keep the login/register verification hook disabled.
# Set TURNSTILE_REQUIRED=true only after the frontend widget passes verificationToken.
# TURNSTILE_SECRET_KEY=
# TURNSTILE_REQUIRED=false
# TURNSTILE_SITEVERIFY_URL=https://challenges.cloudflare.com/turnstile/v0/siteverify

# === OAuth Login / Account Linking (Optional) ===
# Set AUTH_MODE=logto to let Logto own all user sign-in. The app still maps Logto users to local game users.
# OAuth token encryption key (>=32 characters). When set, OAuth access/refresh
# tokens stored in DB are encrypted with this independent key instead of JWT_SECRET.
# Generate with: openssl rand -hex 32
# OAUTH_TOKEN_ENCRYPTION_KEY=
# AUTH_MODE=hybrid
# Public site URL used to build OAuth callback URLs, for example https://example.com
# Callback path format: /api/oauth/:provider/callback
# OAUTH_PUBLIC_BASE_URL=
# Logto is recommended when you already use it to manage social providers.
# Configure callback URL in Logto: https://example.com/api/oauth/logto/callback
# LOGTO_ENDPOINT=https://auth.example.com
# LOGTO_ISSUER=https://auth.example.com/oidc
# LOGTO_DISCOVERY_URL=https://auth.example.com/oidc/.well-known/openid-configuration
# LOGTO_APP_ID=
# LOGTO_APP_SECRET=
# LOGTO_OAUTH_SCOPE=openid profile email
# Optional account security page shown from the in-app profile page.
# LOGTO_ACCOUNT_CENTER_URL=https://auth.example.com/account/security
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GITHUB_OAUTH_CLIENT_ID=
# GITHUB_OAUTH_CLIENT_SECRET=
# DISCORD_OAUTH_CLIENT_ID=
# DISCORD_OAUTH_CLIENT_SECRET=

# === API Server ===
API_PORT=3001

# === Game Server ===
PORT=3000

# === Multiplayer Platform Server (Colyseus) ===
PLATFORM_PORT=3002
# memory is suitable for local development; use redis for multi-instance production.
PLATFORM_REDIS_MODE=memory
# Browser endpoint for Colyseus. Leave empty to derive from the current host
# (localhost:3000 -> ws://localhost:3002, https origin -> same host via wss).
VITE_PLATFORM_URL=

# === Chat Moderation ===
# Comma- or newline-separated keyword lists. Blocked messages are persisted as
# evidence but hidden from chat history; review messages stay visible with a
# pending_review moderation status for admin follow-up.
# CHAT_BLOCKED_WORDS=
# CHAT_REVIEW_WORDS=

# CORS allowed origins (comma-separated, optional)
# ALLOWED_ORIGINS=https://example.com,https://app.example.com

# === Application Version ===
# 預設值僅供本機開發，正式部署必須覆寫。版本號 source of truth 為根目錄 package.json。
APP_VERSION=
APP_BUILD_ID=
GAME_RULES_VERSION=

# === Error Tracking (GlitchTip / Sentry compatible) ===
# Backend DSN (game server + api server). Leave empty to disable.
# SENTRY_DSN=
# Frontend DSN (exposed to browser via VITE_ prefix). Leave empty to disable.
# VITE_SENTRY_DSN=
# VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
# 顯式設定環境名稱（production/staging/preview），未設定時前端退回 Vite MODE、後端退回 NODE_ENV。
# 多環境部署時建議顯式設定，以便在 GlitchTip 後台區分錯誤來源。
# SENTRY_ENVIRONMENT=production
# VITE_SENTRY_ENVIRONMENT=production
# Source map upload（僅用於 build/CI，不會進入前端 bundle）。
# 在 GlitchTip 後台建立 Organization → Project → Auth Token 後填入。
# 未設定時 vite build 仍會產生 source map（hidden），但不會上傳到 GlitchTip。
# SENTRY_URL=https://glitchtip.example.com
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=zutomayo-card-frontend
# SENTRY_AUTH_TOKEN=your_glitchtip_auth_token
# Release 識別：建議在 CI 中設為 git commit hash，確保每次部署有獨立 release。
# APP_BUILD_ID 預設值僅供本機開發，正式部署必須覆蓋。
# GAME_RULES_VERSION 規則相容性改版時可手動指定，否則跟隨 APP_VERSION。

# === Observability (Structured Logging + Metrics) ===
# pino log level (trace/debug/info/warn/error/fatal). Default: info
# LOG_LEVEL=info
# Max Socket.IO connections per IP on the game server. Default: 10
# MAX_CONN_PER_IP=10
# Prometheus metrics exposed at /metrics on both game (3000) and api (3001).
# Scrape: http://<host>:3000/metrics  and  http://<host>:3001/metrics
# Bearer token required to access /metrics. Leave unset to allow unauthenticated
# access (development only). Production must set a strong token.
# METRICS_TOKEN=

# === Analytics (Optional) ===
# VITE_UMAMI_WEBSITE_ID=
# VITE_UMAMI_SCRIPT_URL=
# VITE_UMAMI_HOST_URL=
# VITE_UMAMI_TELEMETRY_SCRIPT_URL=
# VITE_UMAMI_SECONDARY_WEBSITE_ID=
# VITE_UMAMI_SECONDARY_HOST_URL=

# === Card Images (imgproxy) ===
# Frontend generated image URLs default to /api/imgproxy/...; the API server signs,
# requests imgproxy over the Docker/private network, and streams image bytes back.
# Keep IMGPROXY_KEY/SALT server-side only.
# Server4 production:
# IMGPROXY_INTERNAL_BASE_URL=http://imgproxy:8080
# IMGPROXY_KEY=
# IMGPROXY_SALT=
# IMGPROXY_ALLOWED_SOURCES=https://r2.dan.tw/cards/
# Card images are treated as stable assets. If an image is replaced at the same
# R2 URL, purge CDN/browser caches or change the image URL.
# IMGPROXY_CACHE_CONTROL=public, max-age=31536000, immutable
# RATE_LIMIT_IMGPROXY=600
# Optional frontend override. Do not point this at a signed imgproxy host unless that
# host accepts unsigned public URLs; the default /api/imgproxy path is recommended.
# VITE_IMGPROXY_BASE_URL=/api/imgproxy

# === Maintenance ===
# Stale match cleanup (in milliseconds)
STALE_MATCH_TTL_MS=1800000
CLEANUP_INTERVAL_MS=300000

# === Card Seeding (Optional) ===
# SEED_CARDS_URL=
# SEED_CARD_API_URL=

# === PostgreSQL Backup (Optional, see scripts/pg-backup.sh) ===
# PG_BACKUP_DIR=/var/backups/zutomayo
# PG_BACKUP_RETENTION_DAYS=7
