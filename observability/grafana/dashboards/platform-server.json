  },
  "description": "Platform server (Colyseus) metrics - active rooms, connections, match participants, chat messages, Redis latency.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Active Rooms",
      "description": "Number of active Colyseus rooms by room type. Requires a custom platform_active_rooms gauge (label: room_type).",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        {
          "expr": "sum by (room_type) (platform_active_rooms{job=\"zutomayo-platform\"})",
          "legendFormat": "{{room_type}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Active Connections",
      "description": "Active Colyseus WebSocket connections. Requires a custom platform_active_connections gauge.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        {
          "expr": "platform_active_connections{job=\"zutomayo-platform\"}",
          "legendFormat": "connections",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Match Participants",
      "description": "Current match participants across match_shell & quick_match rooms. Requires a custom platform_match_participants gauge.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        {
          "expr": "platform_match_participants{job=\"zutomayo-platform\"}",
          "legendFormat": "participants",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Chat Messages Rate",
      "description": "Chat messages per second. Requires a custom platform_chat_messages_total counter.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "bars", "fillOpacity": 50 }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        {
          "expr": "sum(rate(platform_chat_messages_total{job=\"zutomayo-platform\"}[5m]))",
          "legendFormat": "messages/s",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Redis Operations Latency",
      "description": "Redis operation latency histogram quantiles. Requires a custom platform_redis_operation_duration_seconds histogram.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 5 }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(platform_redis_operation_duration_seconds_bucket{job=\"zutomayo-platform\"}[5m])))",
          "legendFormat": "P50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(platform_redis_operation_duration_seconds_bucket{job=\"zutomayo-platform\"}[5m])))",
          "legendFormat": "P95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(platform_redis_operation_duration_seconds_bucket{job=\"zutomayo-platform\"}[5m])))",
          "legendFormat": "P99",
          "refId": "C"
        }
      ]
    }
  ],
  "refresh": "15s",
  "schemaVersion": 39,
  "tags": ["zutomayo", "platform-server", "colyseus"],
