{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Game server (boardgame.io) metrics - WebSocket connections, HTTP latency, error rate, rate limit, Node.js runtime, PG pool.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Active WebSocket Connections",
      "description": "Active Socket.IO connections (active_socket_connections gauge).",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "stacking": { "mode": "none" }
          }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        {
          "expr": "active_socket_connections",
          "legendFormat": "connections",
          "refId": "A"
        }
      ]
    },
    {
      "title": "HTTP Request Rate (by route)",
      "description": "Requests per second grouped by normalized path.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "right" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum by (path) (rate(http_requests_total{job=\"zutomayo-game\"}[5m]))",
          "legendFormat": "{{path}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "HTTP Request Latency (P50 / P95 / P99)",
      "description": "Histogram quantiles of http_request_duration_seconds.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 5 }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"zutomayo-game\"}[5m])))",
          "legendFormat": "P50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"zutomayo-game\"}[5m])))",
          "legendFormat": "P95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"zutomayo-game\"}[5m])))",
          "legendFormat": "P99",
          "refId": "C"
        }
      ]
    },
    {
      "title": "Error Rate (5xx ratio)",
      "description": "Percentage of HTTP responses with status 5xx.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green" }, { "color": "orange", "value": 0.02 }, { "color": "red", "value": 0.05 }]
          },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"zutomayo-game\",status=~\"5..\"}[5m])) / clamp_min(sum(rate(http_requests_total{job=\"zutomayo-game\"}[5m])), 1e-9)",
          "legendFormat": "5xx ratio",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Rate Limit Triggers",
      "description": "Requests rejected by rate limiter (rate_limited_requests_total). Requires a custom counter on the game server.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "bars", "fillOpacity": 50 }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        {
          "expr": "sum(rate(rate_limited_requests_total{job=\"zutomayo-game\"}[5m]))",
          "legendFormat": "rate-limited/s",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Node.js Event Loop Lag",
      "description": "Event loop lag in seconds from default Node.js metrics.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green" }, { "color": "orange", "value": 0.05 }, { "color": "red", "value": 0.1 }]
          },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        {
          "expr": "nodejs_eventloop_lag_seconds{job=\"zutomayo-game\"}",
          "legendFormat": "lag",
          "refId": "A"
        },
        {
          "expr": "nodejs_eventloop_lag_p99_seconds{job=\"zutomayo-game\"}",
          "legendFormat": "p99 lag",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Memory Usage (Heap)",
      "description": "Node.js heap used vs total.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        {
          "expr": "nodejs_heap_size_used_bytes{job=\"zutomayo-game\"}",
          "legendFormat": "used",
          "refId": "A"
        },
        {
          "expr": "nodejs_heap_size_total_bytes{job=\"zutomayo-game\"}",
          "legendFormat": "total",
          "refId": "B"
        }
      ]
    },
    {
      "title": "PG Pool Connections",
      "description": "PostgreSQL pool connections (idle / total / waiting). Requires a custom pg_pool_* gauge to be exported by the game server.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        {
          "expr": "pg_pool_total{job=\"zutomayo-game\"}",
          "legendFormat": "total",
          "refId": "A"
        },
        {
          "expr": "pg_pool_idle{job=\"zutomayo-game\"}",
          "legendFormat": "idle",
          "refId": "B"
        },
        {
          "expr": "pg_pool_waiting{job=\"zutomayo-game\"}",
          "legendFormat": "waiting",
          "refId": "C"
        }
      ]
    }
  ],
  "refresh": "15s",
  "schemaVersion": 39,
  "tags": ["zutomayo", "game-server", "boardgame-io"],
